%h1.mb-4= @proposal.title

.d-flex.gap-2.mb-4
  = link_to "一覧に戻る", group_proposals_path(@group), class: "btn btn-secondary"
  - if policy(@proposal).edit?
    = link_to "編集", edit_group_proposal_path(@group, @proposal), class: "btn btn-primary"
  - if policy(@proposal).destroy?
    = button_to "削除", group_proposal_path(@group, @proposal), method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "本当に削除しますか？" } }

.card.mb-4
  .card-header
    %h5.mb-0 提案詳細
  .card-body
    %p
      %strong タイトル:
      = @proposal.title
    %div
      %strong 内容:
      %br
      = simple_format(@proposal.content)
    %p
      %strong 作成者:
      = @proposal.user.email
    %p
      %strong ステータス:
      - case @proposal.status
      - when 'pending'
        %span.badge.bg-warning 保留中
      - when 'approved'
        %span.badge.bg-success 承認済み
      - when 'rejected'
        %span.badge.bg-danger 却下
    %p
      %strong 作成日時:
      = @proposal.created_at.strftime("%Y年%m月%d日 %H:%M")

-# TODO: viewからロジックを分離する
.card.mb-4
  .card-header
    %h5.mb-0 投票状況
  .card-body
    - approve_count = @proposal.votes.status_approve.count
    - reject_count = @proposal.votes.status_reject.count
    - member_count = @group.members.count
    - threshold = (member_count / 2) + 1
    - total_votes = approve_count + reject_count
    - approve_pct = total_votes > 0 ? (approve_count.to_f / total_votes * 100).round : 0
    - reject_pct = total_votes > 0 ? 100 - approve_pct : 0

    .d-flex.gap-3.mb-3
      %span.badge.bg-success.fs-6
        %i.bi.bi-hand-thumbs-up.me-1
        賛成 #{approve_count}
      %span.badge.bg-danger.fs-6
        %i.bi.bi-hand-thumbs-down.me-1
        反対 #{reject_count}

    - if total_votes > 0
      .progress.mb-2{ style: "height: 20px" }
        .progress-bar.bg-success{ role: "progressbar", style: "width: #{approve_pct}%", "aria-valuenow": approve_count, "aria-valuemin": "0", "aria-valuemax": total_votes }
          #{approve_pct}%
        .progress-bar.bg-danger{ role: "progressbar", style: "width: #{reject_pct}%", "aria-valuenow": reject_count, "aria-valuemin": "0", "aria-valuemax": total_votes }
          #{reject_pct}%

    %p.text-muted.small
      決定には #{threshold} 票必要（メンバー数: #{member_count}）

    - current_vote = @proposal.votes.find_by(user: current_user)
    - if current_vote
      .alert.alert-secondary.py-2
        あなたの投票:
        - if current_vote.status_approve?
          %span.badge.bg-success
            %i.bi.bi-hand-thumbs-up.me-1
            賛成
        - else
          %span.badge.bg-danger
            %i.bi.bi-hand-thumbs-down.me-1
            反対
    - elsif @proposal.user != current_user && policy(Vote.new(proposal: @proposal, user: current_user)).create?
      .d-flex.gap-2
        = button_to proposal_votes_path(@proposal), params: { vote: { status: :approve } }, class: "btn btn-success" do
          %i.bi.bi-hand-thumbs-up.me-1
          賛成
        = button_to proposal_votes_path(@proposal), params: { vote: { status: :reject } }, class: "btn btn-danger" do
          %i.bi.bi-hand-thumbs-down.me-1
          反対
