= simple_form_for [ @group, @proposal ] do |f|
  = f.error_notification

  = f.input :title, label: "タイトル", placeholder: "提案のタイトルを入力してください"

  = f.input :content, as: :text, label: "内容", input_html: { rows: 10 }, placeholder: "提案の内容を入力してください"

  .d-flex.gap-2
    = f.submit @proposal.new_record? ? "作成" : "更新", class: "btn btn-primary"
    = link_to "キャンセル", group_proposals_path(@group), class: "btn btn-secondary"
