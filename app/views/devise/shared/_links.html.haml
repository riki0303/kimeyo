.mt-3.text-center
  - if controller_name != 'sessions'
    = link_to "ログインはこちら", new_session_path(resource_name), class: "d-block mb-1"
  - if devise_mapping.registerable? && controller_name != 'registrations'
    = link_to "新規登録はこちら", new_registration_path(resource_name), class: "d-block mb-1"
  - if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations'
    = link_to "パスワードを忘れた方はこちら", new_password_path(resource_name), class: "d-block mb-1"
  - if devise_mapping.confirmable? && controller_name != 'confirmations'
    = link_to "確認メールが届かない方はこちら", new_confirmation_path(resource_name), class: "d-block mb-1"
  - if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks'
    = link_to "ロック解除メールが届かない方はこちら", new_unlock_path(resource_name), class: "d-block mb-1"
  - if devise_mapping.omniauthable?
    - resource_class.omniauth_providers.each do |provider|
      = button_to "#{OmniAuth::Utils.camelize(provider)} でサインイン", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "btn btn-outline-secondary w-100 mt-1"
