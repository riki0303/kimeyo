%h2 Sign up
= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
  = f.error_notification

  = f.input :email, autofocus: true, autocomplete: "email"

  = f.input :password, autocomplete: "new-password", hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length)

  = f.input :password_confirmation, autocomplete: "new-password"

  = f.button :submit, "Sign up", class: "btn btn-primary"
= render "devise/shared/links"
