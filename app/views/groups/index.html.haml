.d-flex.justify-content-between.align-items-center.mb-4
  %h1.mb-0 グループ一覧
  = link_to "新規グループ作成", new_group_path, class: "btn btn-primary"

- if @groups.any?
  .row
    - @groups.each do |group|
      .col-md-6.col-lg-4.mb-3
        .card.h-100
          .card-body
            %h5.card-title= group.name
            %p.card-text.text-muted.small
              %i.bi.bi-people-fill.me-1
              メンバー数: #{group.members.count}
          .card-footer.bg-transparent
            = link_to "詳細", group_path(group), class: "btn btn-sm btn-outline-primary"
- else
  .alert.alert-info
    グループがありません。新規グループを作成してください。
